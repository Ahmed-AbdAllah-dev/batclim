{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "Title",
      "required": true
    },
    "description": {
      "type": "blocks",
      "required": true
    },
    "icon": {
      "type": "string",
      "default": "Snowflake",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "order": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "features": {
      "type": "component",
      "component": "service.feauters",
      "repeatable": true
    }
  }
}
